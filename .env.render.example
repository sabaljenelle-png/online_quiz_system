APP_NAME="Online Quiz System"
APP_ENV=production
APP_KEY=base64:PASTE_YOUR_GENERATED_APP_KEY_HERE
APP_DEBUG=false
APP_URL=https://your-render-service-name.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=PASTE_RENDER_POSTGRES_HOST
DB_PORT=5432
DB_DATABASE=PASTE_RENDER_POSTGRES_DATABASE
DB_USERNAME=PASTE_RENDER_POSTGRES_USER
DB_PASSWORD=PASTE_RENDER_POSTGRES_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Set to true for first deploy only if you want demo accounts inserted.
# After successful first deploy, change it back to false.
RUN_SEEDERS=false
